<Page
    x:Class="Proton.Mail.Views.ConversationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Proton.Mail.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.Subject}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12" />

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Messages}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:MailMessageDetail">
                    <Border Padding="12" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="4">
                        <StackPanel Spacing="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontWeight="SemiBold">
                                    <Run Text="{x:Bind SenderName}" />
                                    <Run Text="{x:Bind SenderAddress}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{x:Bind SentAt}" Opacity="0.6" />
                            </Grid>
                            <TextBlock Text="{x:Bind Body}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
