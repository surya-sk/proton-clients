<Page
    x:Class="Proton.Mail.Views.InboxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Proton.Mail.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Inbox" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12" />

        <ListView
            x:Name="ConversationListView"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Conversations}"
            SelectionMode="Single"
            SelectionChanged="ConversationListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConversationSummary">
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock>
                                <Run Text="{x:Bind UnreadMarker}" />
                                <Run Text="{x:Bind SenderName}" FontWeight="SemiBold" />
                                <Run Text=" - " />
                                <Run Text="{x:Bind Subject}" />
                            </TextBlock>
                            <TextBlock Text="{x:Bind Preview}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind ReceivedAt}" Opacity="0.6" VerticalAlignment="Top" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
