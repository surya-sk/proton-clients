<Page
    x:Class="Proton.Calendar.Views.DayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Proton.Calendar.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="{x:Bind ViewModel.DayLabel}" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Content="&lt;" Command="{x:Bind ViewModel.PreviousDayCommand}" />
            <Button Content="&gt;" Command="{x:Bind ViewModel.NextDayCommand}" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Events}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarEvent">
                    <Border Padding="12" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="4">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind TimeRangeLabel}" Opacity="0.7" />
                            <TextBlock Text="{x:Bind Location}" Opacity="0.6" Visibility="{x:Bind HasLocation}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
