<Page
    x:Class="Proton.Calendar.Views.MonthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Proton.Calendar.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="{x:Bind ViewModel.MonthLabel}" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Content="&lt;" Command="{x:Bind ViewModel.PreviousMonthCommand}" />
            <Button Content="Today" Command="{x:Bind ViewModel.TodayCommand}" />
            <Button Content="&gt;" Command="{x:Bind ViewModel.NextMonthCommand}" />
        </StackPanel>

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Days}" SelectionMode="None" IsItemClickEnabled="False">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarDayCell">
                    <Border
                        Width="130"
                        Height="110"
                        Padding="6"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Opacity="{x:Bind CellOpacity}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind DayNumberLabel}" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind Events}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:CalendarEvent">
                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            FontSize="11"
                                            TextTrimming="CharacterEllipsis"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
