<Page
    x:Class="Proton.Calendar.Views.EventEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" RowSpacing="12" MaxWidth="480" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New event" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBox Grid.Row="1" Header="Title" Text="{x:Bind ViewModel.Title, Mode=TwoWay}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <DatePicker Header="Start date" Date="{x:Bind ViewModel.StartDate, Mode=TwoWay}" />
            <TimePicker Header="Start time" Time="{x:Bind ViewModel.StartTime, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <DatePicker Header="End date" Date="{x:Bind ViewModel.EndDate, Mode=TwoWay}" />
            <TimePicker Header="End time" Time="{x:Bind ViewModel.EndTime, Mode=TwoWay}" />
        </StackPanel>

        <TextBox Grid.Row="4" Header="Location" Text="{x:Bind ViewModel.Location, Mode=TwoWay}" />

        <TextBox
            Grid.Row="5"
            Header="Description"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            Height="100"
            Text="{x:Bind ViewModel.Description, Mode=TwoWay}" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <InfoBar
                IsOpen="{x:Bind ViewModel.IsSaved, Mode=OneWay}"
                Severity="Success"
                Message="Event saved."
                IsClosable="False" />
            <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}" />
            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.SaveCommand}" />
        </StackPanel>
    </Grid>
</Page>
