<Page
    x:Class="Proton.Calendar.Views.WeekPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Proton.Calendar.Models">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="{x:Bind ViewModel.WeekLabel}" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Content="&lt;" Command="{x:Bind ViewModel.PreviousWeekCommand}" />
            <Button Content="&gt;" Command="{x:Bind ViewModel.NextWeekCommand}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:CalendarDayColumn">
                        <Border
                            Width="180"
                            Padding="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            VerticalAlignment="Stretch">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind HeaderLabel}" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{x:Bind Events}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:CalendarEvent">
                                            <Border Padding="6" Margin="0,0,0,4" CornerRadius="4" Background="{ThemeResource AccentFillColorDefaultBrush}">
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Title}" FontSize="12" Foreground="White" TextWrapping="Wrap" />
                                                    <TextBlock Text="{x:Bind TimeRangeLabel}" FontSize="11" Foreground="White" Opacity="0.85" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
