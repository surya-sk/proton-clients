<Page
    x:Class="Proton.Pass.Views.PasswordGeneratorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" RowSpacing="16" MaxWidth="420" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Password generator" Style="{StaticResource TitleTextBlockStyle}" />

        <Border
            Grid.Row="1"
            Padding="12"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox
                    Width="300"
                    IsReadOnly="True"
                    FontFamily="Consolas"
                    Text="{x:Bind ViewModel.GeneratedPassword, Mode=OneWay}" />
                <Button Content="Regenerate" Command="{x:Bind ViewModel.RegenerateCommand}" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="{x:Bind ViewModel.Length, Mode=OneWay}" />
            <Slider Minimum="8" Maximum="64" Value="{x:Bind ViewModel.Length, Mode=TwoWay}" Header="Length" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="8">
            <CheckBox Content="Uppercase (A-Z)" IsChecked="{x:Bind ViewModel.IncludeUppercase, Mode=TwoWay}" />
            <CheckBox Content="Lowercase (a-z)" IsChecked="{x:Bind ViewModel.IncludeLowercase, Mode=TwoWay}" />
            <CheckBox Content="Digits (2-9)" IsChecked="{x:Bind ViewModel.IncludeDigits, Mode=TwoWay}" />
            <CheckBox Content="Symbols (!@#$...)" IsChecked="{x:Bind ViewModel.IncludeSymbols, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
            <Button Content="Copy to clipboard" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.CopyToClipboardCommand}" />
            <InfoBar
                IsOpen="{x:Bind ViewModel.IsCopied, Mode=OneWay}"
                Severity="Success"
                Message="Copied."
                IsClosable="False" />
        </StackPanel>
    </Grid>
</Page>
